# Copy this file to terraform.auto.tfvars and fill in real values.
# subscription_id and tenant_id may also be supplied via TF_VAR_* env vars in CI.
subscription_id = "00000000-0000-0000-0000-000000000000"
tenant_id       = "00000000-0000-0000-0000-000000000000"
location        = "uaenorth"
name_prefix     = "prod-uaen"

# Hub-and-spoke addressing - must NOT overlap each other, dev, staging, or any on-prem range.
hub_vnet_address_space   = ["10.10.0.0/16"]
spoke_vnet_address_space = ["10.20.0.0/16"]

aks_admin_group_object_ids = [
  # "<aad-group-object-id-of-platform-admins>"
]

kv_admin_principal_ids = [
  # "<service-principal-object-id-running-terraform>"
]

acr_geo_replication_locations = [
  # "uaecentral"
]

# App Service
appsvc_app_name       = "prod-uaen-app-api"
appsvc_plan_sku       = "P1v3"
appsvc_zone_redundant = true
appsvc_worker_count   = 3

# Log Analytics sizing
log_retention_days = 90
log_daily_quota_gb = 50

# Storage subresources to expose via private endpoint (blob is always on).
storage_enable_file_endpoint  = false
storage_enable_queue_endpoint = false
storage_enable_table_endpoint = false
storage_enable_dfs_endpoint   = false

alert_email_receivers = [
  "platform-oncall@example.com"
]

tags = {
  environment = "production"
  region      = "uae-north"
  owner       = "platform-team"
  cost_center = "eng-platform"
  managed_by  = "terraform"
}
