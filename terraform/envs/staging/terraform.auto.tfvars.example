# Copy to terraform.auto.tfvars (gitignored). Auto-loaded on `terraform plan/apply`.
# Only the must-fill values are listed here -- env-specific defaults are baked
# into variables.tf (override here if you need to deviate).

subscription_id = "00000000-0000-0000-0000-000000000000"
tenant_id       = "00000000-0000-0000-0000-000000000000"

aks_admin_group_object_ids = [
  # "<aad-group-object-id-of-staging-admins>"
]

kv_admin_principal_ids = [
  # "<service-principal-object-id-running-terraform>"
]

alert_email_receivers = [
  "platform-staging@example.com"
]

# Optional overrides (defaults in variables.tf):
