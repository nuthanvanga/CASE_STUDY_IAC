# Copy to staging.tfvars and fill in real values.
# terraform apply -var-file=envs/staging.tfvars

subscription_id = "00000000-0000-0000-0000-000000000000"
tenant_id       = "00000000-0000-0000-0000-000000000000"

environment = "staging"
location    = "uaenorth"
name_prefix = "stg-uaen"

# Hub-and-spoke addressing - must NOT overlap dev, prod or any on-prem range.
hub_vnet_address_space   = ["10.50.0.0/16"]
spoke_vnet_address_space = ["10.60.0.0/16"]

aks_admin_group_object_ids = [
  # "<aad-group-object-id-of-staging-admins>"
]

kv_admin_principal_ids = [
  # "<service-principal-object-id-running-terraform>"
]

acr_geo_replication_locations = []

appsvc_app_name       = "stg-uaen-app-api"
appsvc_plan_sku       = "S1"
appsvc_zone_redundant = false
appsvc_worker_count   = 2

log_retention_days = 60
log_daily_quota_gb = 20

storage_enable_file_endpoint  = false
storage_enable_queue_endpoint = false
storage_enable_table_endpoint = false
storage_enable_dfs_endpoint   = false

alert_email_receivers = [
  "platform-staging@example.com"
]

tags = {
  environment = "staging"
  region      = "uae-north"
  owner       = "platform-team"
  cost_center = "eng-platform"
  managed_by  = "terraform"
}
